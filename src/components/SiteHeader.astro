---
// Sticky page header shared by the readable site ("/") and the terminal page
// ("/TUI"). The wrapper + logo are identical on both; the right-side control
// differs per page and is supplied via the default slot.
import { identity } from '../lib/site';

// The logo is a home link. On the landing page and the terminal it scrolls to
// the top of the current page (`#top`) instead — both already *are* home, and
// linking the terminal to "/" would just bounce back to /TUI via the bot-guard.
const path = Astro.url.pathname;
const homeHref = path === '/' || path.startsWith('/TUI') ? '#top' : '/';
---

<header
  class="sticky top-0 z-30 flex items-center justify-between px-5 py-[14px] sm:px-10 bg-[rgba(11,14,12,0.82)] backdrop-blur-[10px] border-b border-edge"
>
  <a href={homeHref} class="font-mono text-[14px] font-medium text-acc no-underline">{identity.handle}:~$</a>
  <slot />
</header>
