---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { getProjects } from '../lib/github';
import { sortGames } from '../lib/games';
import { identity, contact, hasLinkedIn, skillGroups, languages, education, cvProfile } from '../lib/site';

// A downloadable CV assembled from the SAME sources as the rest of the site, so
// it can never drift: the `work` collection (formal `cv*` projection), GitHub
// `projects`, curated `games`, `skillGroups`, `languages`, `education`, identity
// and contact. Rendered as a light "paper" résumé that prints/saves to PDF
// cleanly via the browser (no server, no PDF dependency — this is a static site).

const jobs = (await getCollection('work', (e) => !e.data.draft)).sort((a, b) => a.data.order - b.data.order);
const experience = jobs.map((j) => ({
  role: j.data.cvRole ?? j.data.role,
  company: j.data.company,
  period: j.data.period,
  location: j.data.location,
  summary: j.data.cvSummary ?? j.data.summary,
  highlights: j.data.cvHighlights.length ? j.data.cvHighlights : [],
  stack: j.data.stack,
}));

const projects = await getProjects();
const games = sortGames(await getCollection('games', (e) => !e.data.draft));

// Friendly section titles from the skill-group labels ("languages/" -> "Languages").
const groupTitle = (label: string) => {
  const base = label.replace(/\/$/, '');
  return base.charAt(0).toUpperCase() + base.slice(1);
};

// Canonical site URL for the contact line + "link to my website".
const siteUrl = Astro.site ?? new URL('https://mkociola.github.io');
const siteHost = siteUrl.host;
---

<Base title={`${identity.name} — CV`} description={`Curriculum vitae of ${identity.name}, ${identity.title}.`}>
  <div class="cv-stage">
    <div class="cv-toolbar">
      <a class="cv-tool-link" href="/">‹ back to site</a>
      <button id="cv-print" type="button" class="cv-tool-btn">Download PDF ↓</button>
    </div>

    <article class="cv-paper">
      <!-- Header -->
      <header class="cv-head">
        <h1 class="cv-name">{identity.name}</h1>
        <div class="cv-role">{identity.role} · {identity.title}</div>
        <div class="cv-contact">
          <span>{identity.location}</span>
          <!-- Email/phone are base64 in the markup and assembled by JS on load, so
               they never ship as plain text for scrapers (consistent with the rest
               of the site) while still appearing in the rendered/printed PDF. -->
          <a class="cv-c" data-cv-reveal data-d={contact.email.displayB64} data-h={contact.email.hrefB64}>email</a>
          <a class="cv-c" data-cv-reveal data-d={contact.phone.displayB64} data-h={contact.phone.hrefB64}>phone</a>
          <a href={contact.github.url}>{contact.github.label}</a>
          {hasLinkedIn && <a href={contact.linkedin.url}>linkedin</a>}
          <a href={siteUrl.href}>{siteHost}</a>
        </div>
      </header>

      <!-- Summary -->
      <section class="cv-section">
        <h2 class="cv-h2"><span class="cv-no">//</span> summary</h2>
        <p class="cv-summary">{cvProfile}</p>
      </section>

      <!-- Experience -->
      <section class="cv-section">
        <h2 class="cv-h2"><span class="cv-no">//</span> experience</h2>
        {
          experience.map((job) => (
            <div class="cv-job">
              <div class="cv-job-head">
                <div class="cv-job-title">
                  {job.role} <span class="cv-at">@ {job.company}</span>
                </div>
                <div class="cv-job-period">{job.period}</div>
              </div>
              {job.location && <div class="cv-job-loc">{job.location}</div>}
              <p class="cv-job-summary">{job.summary}</p>
              <ul class="cv-bullets">
                {job.highlights.map((h) => (
                  <li>{h}</li>
                ))}
              </ul>
              {job.stack.length > 0 && <div class="cv-stack">{job.stack.join(' · ')}</div>}
            </div>
          ))
        }
      </section>

      <!-- Projects -->
      <section class="cv-section">
        <h2 class="cv-h2"><span class="cv-no">//</span> selected projects</h2>
        <ul class="cv-projects">
          {
            games.map((g) => (
              <li>
                <span class="cv-proj-name">{g.data.name}</span>
                <span class="cv-proj-meta">
                  {g.data.platform} · {g.data.status === 'live' ? 'on the App Store' : 'in App Store review'}
                </span>
                <div class="cv-proj-desc">{g.data.tagline}</div>
              </li>
            ))
          }
          {
            projects.map((p) => (
              <li>
                <span class="cv-proj-name">{p.name}</span>
                <span class="cv-proj-meta">{[p.language, p.stars > 0 ? `★ ${p.stars}` : null].filter(Boolean).join(' · ')}</span>
                <div class="cv-proj-desc">{p.description}</div>
              </li>
            ))
          }
        </ul>
        <div class="cv-projects-more">More at {contact.github.label}</div>
      </section>

      <!-- Skills -->
      <section class="cv-section">
        <h2 class="cv-h2"><span class="cv-no">//</span> skills</h2>
        <dl class="cv-skills">
          {
            skillGroups.map((group) => (
              <div class="cv-skill-row">
                <dt>{groupTitle(group.label)}</dt>
                <dd>{group.items.join(' · ')}</dd>
              </div>
            ))
          }
        </dl>
      </section>

      <!-- Education + Languages -->
      <section class="cv-section cv-foot">
        <div class="cv-foot-col">
          <h2 class="cv-h2"><span class="cv-no">//</span> education</h2>
          <div class="cv-edu-cred">{education.credential}</div>
          <div class="cv-edu-note">{education.note}</div>
        </div>
        <div class="cv-foot-col">
          <h2 class="cv-h2"><span class="cv-no">//</span> languages</h2>
          <div class="cv-langs">{languages.map((l) => `${l.name} (${l.level})`).join(' · ')}</div>
        </div>
      </section>
    </article>
  </div>

  <script is:inline>
    // Assemble email/phone from base64 at runtime (never in static HTML).
    document.querySelectorAll('[data-cv-reveal]').forEach(function (el) {
      el.href = atob(el.dataset.h);
      el.textContent = atob(el.dataset.d);
      el.removeAttribute('data-cv-reveal');
    });
    // "Download PDF" = the browser's print-to-PDF (Save as PDF).
    var btn = document.getElementById('cv-print');
    if (btn) btn.addEventListener('click', function () { window.print(); });
  </script>
</Base>

<style is:global>
  /* ------------------------------------------------------------------ *
   * The CV is a light, ATS-friendly "paper" document — its own palette,
   * not the site's dark theme. It reuses the site fonts (Space Grotesk +
   * JetBrains Mono) and a darkened brand green so it reads as part of the
   * same identity while staying legible in print. What you see on screen
   * is exactly what prints (WYSIWYG); the dark surround + toolbar are
   * screen-only.
   * ------------------------------------------------------------------ */
  :root {
    --cv-paper: #ffffff;
    --cv-ink: #1b1f1c;
    --cv-heading: #0f1511;
    --cv-muted: #5b6b60;
    --cv-faint: #7c8a80;
    --cv-acc: #15823a;       /* brand green, darkened for contrast on white */
    --cv-rule: #e4e9e5;
    --cv-chip: #eef2ee;
  }

  .cv-stage {
    min-height: 100vh;
    background: var(--color-page, #060a07);
    padding: 28px 16px 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }

  .cv-toolbar {
    width: 100%;
    max-width: 820px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .cv-tool-link { color: var(--color-muted, #7e9b84); text-decoration: none; }
  .cv-tool-link:hover { color: var(--color-acc, #33ff66); }
  .cv-tool-btn {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: #06140a;
    background: var(--color-acc, #33ff66);
    border: none;
    border-radius: 6px;
    padding: 9px 16px;
    cursor: pointer;
    transition: background-color 0.15s;
  }
  .cv-tool-btn:hover { background: #5cff85; }

  .cv-paper {
    width: 100%;
    max-width: 820px;
    background: var(--cv-paper);
    color: var(--cv-ink);
    font-family: var(--font-sans);
    line-height: 1.5;
    padding: 56px 60px;
    border-radius: 4px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.45);
  }

  /* Header */
  .cv-name {
    margin: 0;
    font-size: 33px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--cv-heading);
  }
  .cv-role {
    margin-top: 4px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--cv-acc);
  }
  .cv-contact {
    margin-top: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px 14px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--cv-muted);
  }
  .cv-contact a { color: var(--cv-muted); text-decoration: none; }
  .cv-contact a:hover { color: var(--cv-acc); }
  .cv-c { cursor: pointer; }

  /* Sections */
  .cv-section { margin-top: 26px; }
  .cv-h2 {
    margin: 0 0 12px;
    padding-bottom: 5px;
    border-bottom: 1px solid var(--cv-rule);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--cv-heading);
  }
  .cv-no { color: var(--cv-acc); }

  .cv-summary { margin: 0; font-size: 14.5px; color: var(--cv-ink); }

  /* Experience */
  .cv-job { margin-bottom: 18px; }
  .cv-job:last-child { margin-bottom: 0; }
  .cv-job-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
  }
  .cv-job-title { font-size: 15.5px; font-weight: 600; color: var(--cv-heading); }
  .cv-at { color: var(--cv-acc); font-weight: 600; }
  .cv-job-period {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--cv-muted);
    white-space: nowrap;
  }
  .cv-job-loc { font-family: var(--font-mono); font-size: 11.5px; color: var(--cv-faint); margin-top: 1px; }
  .cv-job-summary { margin: 6px 0 7px; font-size: 13.5px; color: var(--cv-ink); }
  .cv-bullets { margin: 0; padding: 0; list-style: none; }
  .cv-bullets li {
    position: relative;
    padding-left: 15px;
    margin: 3px 0;
    font-size: 13px;
    color: var(--cv-ink);
  }
  .cv-bullets li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--cv-acc);
  }
  .cv-stack {
    margin-top: 7px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--cv-faint);
  }

  /* Projects */
  .cv-projects { margin: 0; padding: 0; list-style: none; }
  .cv-projects li { margin-bottom: 9px; }
  .cv-proj-name { font-weight: 600; font-size: 13.5px; color: var(--cv-heading); }
  .cv-proj-meta { font-family: var(--font-mono); font-size: 11px; color: var(--cv-faint); margin-left: 8px; }
  .cv-proj-desc { font-size: 12.5px; color: var(--cv-ink); margin-top: 1px; }
  .cv-projects-more { margin-top: 10px; font-family: var(--font-mono); font-size: 11.5px; color: var(--cv-muted); }

  /* Skills */
  .cv-skills { margin: 0; }
  .cv-skill-row { display: grid; grid-template-columns: 110px 1fr; gap: 10px; margin-bottom: 7px; }
  .cv-skill-row dt { font-family: var(--font-mono); font-size: 12px; color: var(--cv-muted); }
  .cv-skill-row dd { margin: 0; font-size: 13px; color: var(--cv-ink); }

  /* Education + Languages */
  .cv-foot { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }
  .cv-edu-cred { font-size: 13.5px; color: var(--cv-ink); }
  .cv-edu-note { font-size: 12.5px; color: var(--cv-muted); margin-top: 2px; }
  .cv-langs { font-size: 13px; color: var(--cv-ink); }

  @media (max-width: 640px) {
    .cv-paper { padding: 36px 26px; }
    .cv-skill-row { grid-template-columns: 1fr; gap: 2px; }
    .cv-foot { grid-template-columns: 1fr; gap: 18px; }
  }

  /* ---- Print: just the paper, edge to edge, ink-friendly ---- */
  @media print {
    @page { margin: 1.4cm; }
    html, body { background: #fff !important; }
    .cv-stage { padding: 0; background: #fff !important; min-height: 0; }
    .cv-toolbar { display: none !important; }
    .cv-paper {
      max-width: none;
      width: 100%;
      padding: 0;
      border-radius: 0;
      box-shadow: none;
    }
    /* Keep the green accents (labels, rules, bullets) in the PDF. */
    .cv-paper, .cv-no, .cv-at, .cv-role, .cv-bullets li::before {
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    .cv-job, .cv-section { break-inside: avoid; }
    a { color: inherit; text-decoration: none; }
  }
</style>
